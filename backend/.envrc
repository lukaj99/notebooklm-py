# NotebookLM API Backend - Direnv configuration
# This file is automatically loaded by direnv when entering the directory

# Virtual environment activation
export VIRTUAL_ENV="$(pwd)/.venv"
layout python

# API configuration (override with NOTEBOOKLM_API_ prefix)
export NOTEBOOKLM_API_HOST=127.0.0.1
export NOTEBOOKLM_API_PORT=8000
export NOTEBOOKLM_API_LOG_LEVEL=info

# Project information
export PROJECT_NAME="notebooklm-api"
export PYTHONPATH="${PWD}/src:${PYTHONPATH}"
