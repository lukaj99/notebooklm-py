{
  "mcpServers": {
    "notebooklm": {
      "transport": "sse",
      "url": "https://notebook.jovanovic.org.uk/mcp",
      "headers": {
        "Authorization": "Bearer <YOUR_API_KEY>"
      },
      "timeout": 30,
      "description": "Google NotebookLM integration - create notebooks, add sources, ask questions, generate artifacts"
    }
  }
}
